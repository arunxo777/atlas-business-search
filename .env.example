# LLM Providers — auto-selects: Ollama → Groq → Mistral → OpenAI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_ONLY=false
OLLAMA_TIMEOUT_SECONDS=180

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Search — SerpAPI + Omkar Google Scraper (https://github.com/omkarcloud/google-scraper)
USE_SERPAPI=true
SERPAPI_KEY=
USE_OMKAR_GOOGLE_SCRAPER=true
USE_RAPIDAPI_GOOGLE=false
RAPIDAPI_GOOGLE_KEY=
GOOGLE_SCRAPER_MAX_RESULTS=20

# Firecrawl — https://github.com/firecrawl/firecrawl
USE_FIRECRAWL=true
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
FIRECRAWL_SEARCH_LIMIT=15

# Proxy pool — https://github.com/naiba/proxy-in-a-box
USE_PROXY_POOL=true
PROXY_POOL_HTTP=http://127.0.0.1:8080
PROXY_POOL_HTTPS=http://127.0.0.1:8081
PROXY_POOL_API=http://127.0.0.1:8083

# App
DATABASE_URL=sqlite+aiosqlite:///./data/research.db
CACHE_TTL_HOURS=24
MAX_CONCURRENT_SCRAPERS=10
MAX_BUSINESSES_PER_QUERY=500
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
